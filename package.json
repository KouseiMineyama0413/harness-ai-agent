{
  "name": "@kouseimineyama/harness-ai-agent",
  "version": "0.1.0",
  "description": "Framework-agnostic development harness: project analysis, quality gates, AI-agent guardrails, structured context and reporting.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KouseiMineyama0413/harness-ai-agent.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "harness": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
